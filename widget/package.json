{
  "name": "widget",
  "version": "1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3003 --hostname 0.0.0.0",
    "build": "next build",
    "start": "next start -p ${PORT:-8080}",
    "test:e2e": "playwright test",
    "test:e2e:update": "playwright test --update-snapshots",
    "test:e2e:report": "playwright show-report tests/e2e/_playwright-report --port 58724",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prettier": "prettier --write . --plugin=prettier-plugin-organize-imports",
    "type-check": "tsc --noEmit"
  },
  "prettier": {
    "printWidth": 180
  },
  "dependencies": {
    "@headlessui/react": "2.2.10",
    "@sentry/cli": "3.4.0",
    "@sentry/nextjs": "10.50.0",
    "@tailwindcss/postcss": "4.2.4",
    "i18n-iso-countries": "7.14.0",
    "next": "16.2.4",
    "next-plausible": "3.12.5",
    "react": "19.2.5",
    "react-datepicker": "9.1.0",
    "react-dom": "19.2.5",
    "react-icons": "5.6.0",
    "react-slick": "0.31.0",
    "sharp": "0.34.5",
    "slick-carousel": "1.8.1",
    "zustand": "5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@next/eslint-plugin-next": "16.2.4",
    "@playwright/test": "1.59.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "^25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/eslint-plugin": "8.59.0",
    "@typescript-eslint/parser": "8.59.0",
    "@vitejs/plugin-react": "5.1.4",
    "autoprefixer": "10.5.0",
    "eslint": "10.2.1",
    "eslint-plugin-import-x": "4.16.2",
    "globals": "17.5.0",
    "postcss": "8.5.10",
    "tailwindcss": "4.2.4",
    "typescript": "5.9.3"
  }
}

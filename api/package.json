{
    "name": "api",
    "version": "1.0.0",
    "description": "",
    "main": "src/index.js",
    "scripts": {
        "taxonomy:build": "tsc -p ../packages/taxonomy/tsconfig.json",
        "dto:build": "tsc -p ../packages/dto/tsconfig.json",
        "build": "npm run taxonomy:build && npm run dto:build && npm run prisma:generate && npx tsc --build --clean && npx tsc -p tsconfig.build.json && npx tsc-alias -p tsconfig.build.json",
        "dev": "nodemon",
        "dev:worker": "nodemon --exec \"ts-node src/worker/index.ts\"",
        "start": "npm run build && node dist/index.js",
        "prisma:migrate:dev": "prisma migrate dev",
        "prisma:migrate:deploy": "prisma migrate deploy",
        "prisma:generate": "prisma generate && echo 'export * from \"./client\"' > src/db/core/index.ts",
        "prettier": "prettier --write . --plugin=prettier-plugin-organize-imports",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "test": "npm run test:unit && npm run test:integration",
        "test:unit": "vitest run --config vitest.unit.config.ts",
        "test:unit:watch": "vitest --config vitest.unit.config.ts",
        "test:integration": "vitest run --config vitest.integration.config.ts",
        "test:integration:watch": "vitest --config vitest.integration.config.ts",
        "test:watch": "npm run test:unit:watch",
        "test:ci": "npm run prisma:generate && npm run test:unit && npm run test:integration",
        "job": "ts-node src/jobs/run-job.ts",
        "worker:run": "ts-node src/worker/run-handler.ts"
    },
    "dependencies": {
        "@ai-sdk/mistral": "3.0.37",
        "@ai-sdk/openai": "3.0.73",
        "@aws-sdk/client-s3": "3.1064.0",
        "@aws-sdk/client-sqs": "3.1064.0",
        "@aws-sdk/lib-storage": "3.1064.0",
        "@aws-sdk/s3-request-presigner": "3.1064.0",
        "@engagement/dto": "file:../packages/dto",
        "@engagement/taxonomy": "file:../packages/taxonomy",
        "@opentelemetry/exporter-metrics-otlp-http": "0.218.0",
        "@opentelemetry/resources": "2.7.1",
        "@opentelemetry/sdk-metrics": "2.7.1",
        "@prisma/adapter-pg": "7.8.0",
        "@prisma/client": "7.8.0",
        "@sentry/node": "10.56.0",
        "@types/geoip-lite": "1.4.4",
        "ai": "6.0.198",
        "bcryptjs": "3.0.3",
        "cookie-parser": "1.4.7",
        "cors": "2.8.6",
        "csv-parse": "6.2.1",
        "dotenv": "^17.4.2",
        "express": "5.2.1",
        "express-rate-limit": "8.5.2",
        "fast-xml-parser": "5.8.0",
        "geoip-lite": "2.0.2",
        "he": "1.2.0",
        "helmet": "8.2.0",
        "html-to-text": "10.0.0",
        "isbot": "5.1.42",
        "jsonwebtoken": "9.0.3",
        "jspdf": "3.0.3",
        "morgan": "1.11.0",
        "multer": "2.1.1",
        "node-cron": "4.2.1",
        "object-hash": "3.0.0",
        "passport": "0.7.0",
        "passport-headerapikey": "1.2.2",
        "passport-jwt": "4.0.1",
        "pg": "8.21.0",
        "prisma": "7.8.0",
        "sharp": "0.34.5",
        "typesense": "3.0.6",
        "uuid": "14.0.0",
        "xlsx": "0.18.5",
        "zod": "4.4.3"
    },
    "devDependencies": {
        "@eslint/js": "10.0.1",
        "@testcontainers/postgresql": "12.0.3",
        "@types/bcryptjs": "3.0.0",
        "@types/body-parser": "1.19.6",
        "@types/cookie-parser": "1.4.10",
        "@types/cors": "2.8.19",
        "@types/express": "5.0.6",
        "@types/he": "1.2.3",
        "@types/html-to-text": "9.0.4",
        "@types/jsonwebtoken": "9.0.10",
        "@types/morgan": "1.9.10",
        "@types/multer": "2.1.0",
        "@types/object-hash": "3.0.6",
        "@types/passport": "1.0.17",
        "@types/passport-jwt": "4.0.1",
        "@types/pg": "8.20.0",
        "@types/supertest": "7.2.0",
        "@types/yauzl": "3.4.0",
        "@typescript-eslint/eslint-plugin": "8.62.0",
        "@typescript-eslint/parser": "8.62.0",
        "eslint": "10.2.1",
        "eslint-plugin-import-x": "4.17.0",
        "express-openapi-validator": "5.6.2",
        "nodemon": "3.1.14",
        "supertest": "7.2.2",
        "ts-node": "10.9.2",
        "tsc-alias": "1.8.17",
        "tsconfig-paths": "4.2.0",
        "typescript": "6.0.3",
        "vitest": "4.1.9"
    }
}

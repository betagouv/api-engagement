{
    "name": "api",
    "version": "1.0.0",
    "description": "",
    "main": "src/index.js",
    "scripts": {
        "build": "npm run prisma:generate && npx tsc --build --clean && npx tsc -p tsconfig.build.json && npx tsc-alias -p tsconfig.build.json",
        "dev": "nodemon",
        "start": "npm run build && node dist/index.js",
        "prisma:migrate:dev": "prisma migrate dev",
        "prisma:migrate:deploy": "prisma migrate deploy",
        "prisma:generate": "prisma generate && echo 'export * from \"./client\"' > src/db/core/index.ts",
        "prettier": "prettier --write . --plugin=prettier-plugin-organize-imports",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "test": "npm run test:unit && npm run test:integration",
        "test:unit": "vitest run --config vitest.unit.config.ts",
        "test:unit:watch": "vitest --config vitest.unit.config.ts",
        "test:integration": "vitest run --config vitest.integration.config.ts",
        "test:integration:watch": "vitest --config vitest.integration.config.ts",
        "test:watch": "npm run test:unit:watch",
        "test:ci": "npm run prisma:generate && npm run test:unit && npm run test:integration",
        "job": "ts-node src/jobs/run-job.ts"
    },
    "dependencies": {
        "@aws-sdk/client-s3": "3.1016.0",
        "@aws-sdk/lib-storage": "3.1016.0",
        "@opentelemetry/exporter-metrics-otlp-http": "0.213.0",
        "@opentelemetry/resources": "2.6.0",
        "@opentelemetry/sdk-metrics": "2.6.0",
        "@prisma/adapter-pg": "7.5.0",
        "@prisma/client": "7.5.0",
        "@sentry/node": "10.45.0",
        "@types/geoip-lite": "1.4.4",
        "bcryptjs": "3.0.3",
        "cookie-parser": "1.4.7",
        "cors": "2.8.6",
        "csv-parse": "6.2.1",
        "dotenv": "17.3.1",
        "express": "5.2.1",
        "express-rate-limit": "8.3.1",
        "fast-xml-parser": "5.5.9",
        "geoip-lite": "2.0.1",
        "he": "1.2.0",
        "helmet": "8.1.0",
        "html-to-text": "9.0.5",
        "isbot": "5.1.36",
        "jsonwebtoken": "9.0.3",
        "jspdf": "3.0.3",
        "morgan": "1.10.1",
        "multer": "2.1.1",
        "node-cron": "4.2.1",
        "object-hash": "3.0.0",
        "passport": "0.7.0",
        "passport-headerapikey": "1.2.2",
        "passport-jwt": "4.0.1",
        "prisma": "7.5.0",
        "sharp": "0.34.5",
        "uuid": "11.1.0",
        "xlsx": "0.18.5",
        "zod": "4.3.6"
    },
    "devDependencies": {
        "@eslint/js": "10.0.1",
        "@testcontainers/postgresql": "11.13.0",
        "@types/bcryptjs": "3.0.0",
        "@types/body-parser": "1.19.6",
        "@types/cookie-parser": "1.4.10",
        "@types/cors": "2.8.19",
        "@types/express": "5.0.6",
        "@types/he": "1.2.3",
        "@types/html-to-text": "9.0.4",
        "@types/jsonwebtoken": "9.0.10",
        "@types/morgan": "1.9.10",
        "@types/multer": "2.1.0",
        "@types/object-hash": "3.0.6",
        "@types/passport": "1.0.17",
        "@types/passport-jwt": "4.0.1",
        "@types/supertest": "7.2.0",
        "@types/uuid": "10.0.0",
        "@types/yauzl": "2.10.3",
        "@typescript-eslint/eslint-plugin": "8.57.2",
        "@typescript-eslint/parser": "8.57.2",
        "eslint": "10.1.0",
        "eslint-plugin-import-x": "4.16.2",
        "express-openapi-validator": "^5.6.2",
        "nodemon": "3.1.14",
        "supertest": "7.2.2",
        "ts-node": "10.9.2",
        "tsc-alias": "^1.8.16",
        "tsconfig-paths": "^4.2.0",
        "typescript": "6.0.2",
        "vitest": "4.1.1"
    }

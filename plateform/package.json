{
  "name": "plateform",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "react-router dev --port 3005",
    "build": "react-router build",
    "start": "react-router-serve ./build/server/index.js",
    "typecheck": "react-router typegen && tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prettier": "prettier --write . --plugin=prettier-plugin-organize-imports",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "prettier": {
    "printWidth": 180
  },
  "dependencies": {
    "@engagement/dto": "file:../packages/dto",
    "@engagement/taxonomy": "file:../packages/taxonomy",
    "@gouvfr/dsfr": "1.14.4",
    "@react-router/node": "7.17.0",
    "@react-router/serve": "7.17.0",
    "@sentry/react": "10.56.0",
    "@tailwindcss/vite": "4.3.0",
    "isbot": "5.1.42",
    "leaflet": "1.9.4",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-leaflet": "5.0.0",
    "react-router": "7.17.0",
    "tailwindcss": "4.3.0",
    "zustand": "5.0.14"
  },
  "devDependencies": {
    "@react-router/dev": "7.17.0",
    "@types/leaflet": "1.9.21",
    "@types/node": "22.15.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/eslint-plugin": "8.61.0",
    "@typescript-eslint/parser": "8.61.0",
    "@vitejs/plugin-react": "6.0.1",
    "@vitest/coverage-v8": "4.1.8",
    "eslint": "9.39.4",
    "globals": "17.6.0",
    "postcss": "8.5.15",
    "prettier": "3.8.3",
    "prettier-plugin-organize-imports": "4.3.0",
    "typescript": "6.0.3",
    "vite": "8.0.16",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "4.1.8"
  }
}

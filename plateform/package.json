    "@tailwindcss/vite": "^4.2.2",
    "isbot": "5.1.27",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-router": "7.6.0",
    "tailwindcss": "^4.2.2",
    "zustand": "5.0.5"
  },
  "devDependencies": {
    "@react-router/dev": "7.6.0",

{
  "name": "api-engagement",
  "version": "1.4.1",
  "workspaces": ["packages/*", "api", "app", "widget", "analytics", "plateform", "poc-quiz"],
  "scripts": {
    "lint": "npm run lint:api && npm run lint:app && npm run lint:analytics && npm run lint:widget",
    "lint:api": "cd api && npm run lint",
    "lint:app": "cd app && npm run lint",
    "lint:analytics": "cd analytics && npm run lint",
    "lint:widget": "cd widget && npm run lint",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md,yml}\" --ignore-path .prettierignore",
    "commit": "cz",
    "prepare": "husky"
  },
  "config": {
    "commitizen": {
      "path": "cz-customizable"
    }
  },
  "devDependencies": {
    "@commitlint/cli": "19.8.1",
    "commitizen": "4.3.1",
    "cz-customizable": "7.5.1",
    "husky": "9.1.7",
    "prettier": "3.5.3",
    "prettier-plugin-organize-imports": "4.1.0",
    "prettier-plugin-tailwindcss": "0.6.11"
  }
}
